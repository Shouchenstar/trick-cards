# LLM 配置：支持市面上所有主流 LLM API。
# 三个协议 provider 可选：openai / anthropic / gemini
#
# 1) OpenAI 兼容（覆盖 OpenAI / DeepSeek / Kimi / 智谱 / 通义 / Groq / Together /
#    SiliconFlow / OpenRouter / Azure OpenAI / Ollama / vLLM / 零一万物 / MiniMax
#    / Mistral / Stepfun 等绝大多数）：
#
#    DeepSeek (推荐):     LLM_PROVIDER=openai
#                          LLM_BASE_URL=https://api.deepseek.com
#                          LLM_MODEL=deepseek-chat
#    OpenAI:               LLM_BASE_URL=https://api.openai.com  LLM_MODEL=gpt-4o-mini
#    通义千问 (DashScope): LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
#                          LLM_MODEL=qwen-plus
#    智谱 BigModel:        LLM_BASE_URL=https://open.bigmodel.cn/api/paas LLM_MODEL=glm-4-flash
#    Kimi:                 LLM_BASE_URL=https://api.moonshot.cn LLM_MODEL=moonshot-v1-8k
#    OpenRouter:           LLM_BASE_URL=https://openrouter.ai/api LLM_MODEL=openai/gpt-4o-mini
#    Groq:                 LLM_BASE_URL=https://api.groq.com/openai LLM_MODEL=llama-3.3-70b-versatile
#    SiliconFlow:          LLM_BASE_URL=https://api.siliconflow.cn LLM_MODEL=deepseek-ai/DeepSeek-V3
#    Ollama (本地):        LLM_BASE_URL=http://localhost:11434 LLM_API_KEY=ollama
#                          LLM_MODEL=llama3.1
#
# 2) Anthropic Messages API（Claude 全系）：
#    LLM_PROVIDER=anthropic
#    LLM_API_KEY=sk-ant-xxxxx
#    LLM_MODEL=claude-sonnet-4-20250514
#    （base_url 留空即可，默认 https://api.anthropic.com）
#
# 3) Google Gemini（Gemini 1.5/2.x）：
#    LLM_PROVIDER=gemini
#    LLM_API_KEY=AIzaSyXXXX
#    LLM_MODEL=gemini-2.5-flash
#    （base_url 留空，默认 https://generativelanguage.googleapis.com）
#
# 也可以不在 .env 配，运行后在右下角「AI 设置」里填，每个用户用自己的 key。

LLM_PROVIDER=openai
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# 可选：Tavily（开放网页检索；https://app.tavily.com 免费 1000 req/月）
# 不填则 Agent 不调网页搜索，只用 arXiv。
TAVILY_API_KEY=

{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "默认权限，允许打开外部链接",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "clipboard-manager:allow-read-image",
    "clipboard-manager:allow-write-text",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://*" }, { "url": "http://*" }]
    }
  ]
}
